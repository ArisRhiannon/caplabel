{
  "name": "caplabel",
  "version": "0.1.2",
  "description": "Offline, zero-dependency static capability analyzer for JavaScript — see what a script can do (network, filesystem, exec, secrets) before you run it.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArisRhiannon/caplabel.git"
  },
  "type": "module",
  "bin": {
    "caplabel": "dist/caplabel.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "security",
    "devsecops",
    "supply-chain",
    "static-analysis",
    "sast",
    "capability",
    "malware",
    "npm",
    "cli",
    "offline",
    "zero-dependency",
    "least-privilege",
    "code-security",
    "javascript",
    "audit"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/cli/bin.ts --target node --outfile dist/caplabel.js",
    "prepublishOnly": "bun run build && bun test"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/bun": "^1.1.0"
  }
}
